name: Release Build

on:
  workflow_dispatch:
  push:
    tags:
      - "w*"

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Set up JDK
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '17'

      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip
          pip --version

      - name: Gradle cache
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/*.gradle*', '**/gradle-wrapper.properties') }}
          restore-keys: |
            ${{ runner.os }}-gradle-

      ##### 🔧 修复：更健壮的签名文件准备 #####
      - name: Prepare signing files
        run: |
          mkdir -p app
          
          # 使用 printf 避免 echo 的换行问题，并严格处理 base64
          printf '%s' "${{ secrets.KEY_BASE64 }}" | base64 -d > app/app.key
          
          # 验证 keystore 文件
          if [ ! -s app/app.key ]; then
            echo "❌ Error: Keystore file is empty or not created!"
            exit 1
          fi
          
          # 检查文件大小（JKS 通常 > 2KB）
          FILE_SIZE=$(stat -c%s app/app.key)
          echo "Keystore file size: $FILE_SIZE bytes"
          
          if [ "$FILE_SIZE" -lt 1000 ]; then
            echo "⚠️ Warning: Keystore file seems too small, might be corrupted"
          fi
          
          # 记录文件哈希（用于对比不同构建）
          echo "Keystore SHA256: $(sha256sum app/app.key | cut -d' ' -f1)"
          
          # 创建 local.properties（使用 here-document 避免变量扩展问题）
          cat > local.properties << 'PROPERTIES_EOF'
          ${{ secrets.SIGNING_CONFIG }}
          PROPERTIES_EOF
          
          # 验证 local.properties（隐藏密码，只显示结构）
          echo "local.properties line count: $(wc -l < local.properties)"
          echo "local.properties content structure:"
          grep -E "^(store|key)" local.properties | sed 's/=.*/=***/' || echo "Warning: Could not parse properties"

      - name: Change package name
        run: |
          sed -i 's/applicationId = "me.rerere.rikkahub.dev"/applicationId = "me.rerere.rikkahub.dev.mod.none"/' app/build.gradle.kts
          echo "✅ Package changed to: me.rerere.rikkahub.dev.mod.none"

      ##### 🔧 修复：确定性构建配置 #####
      - name: Gradle Build
        env:
          GRADLE_OPTS: >
            -Dorg.gradle.daemon=false
            -Dorg.gradle.parallel=false
            -Dorg.gradle.configureondemand=false
            -Xmx6g
            -XX:MaxMetaspaceSize=512m
        run: |
          chmod +x gradlew
          
          # 清理以确保无缓存污染
          ./gradlew clean --no-daemon
          
          # 构建
          ./gradlew assembleRelease --no-daemon --stacktrace

      ##### 🔍 调试：提取并记录签名证书信息 #####
      - name: Extract and verify signature
        run: |
          APK_FILE=$(find app/build/outputs/apk/release -name "*.apk" | head -1)
          
          if [ -z "$APK_FILE" ]; then
            echo "❌ No APK found!"
            exit 1
          fi
          
          echo "Analyzing: $APK_FILE"
          
          # 提取证书信息
          unzip -p "$APK_FILE" META-INF/*.RSA META-INF/*.DSA 2>/dev/null > /tmp/cert.der || true
          
          if [ -f /tmp/cert.der ] && [ -s /tmp/cert.der ]; then
            echo "=== Certificate Details ==="
            keytool -printcert -file /tmp/cert.der 2>/dev/null | tee signature-details.txt
            
            echo ""
            echo "=== Certificate SHA-256 Fingerprint ==="
            keytool -printcert -file /tmp/cert.der 2>/dev/null | grep "SHA256:" | tee -a signature-details.txt
          else
            echo "⚠️ Could not extract certificate (可能未签名或使用不同签名方案)"
            # 尝试 apksigner 验证
            if command -v apksigner &> /dev/null; then
              apksigner verify --print-certs "$APK_FILE" 2>/dev/null | tee signature-details.txt || true
            fi
          fi
          
          # 同时计算 APK 的哈希
          echo ""
          echo "=== APK SHA-256 ==="
          sha256sum "$APK_FILE" | tee -a signature-details.txt

      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        if: success()
        with:
          name: artifacts-${{ github.run_number }}
          path: |
            app/build/outputs/apk/release/*.apk
            signature-details.txt

